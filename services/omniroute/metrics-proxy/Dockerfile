FROM node:24-alpine

WORKDIR /app
ENV NODE_ENV=production     PORT=20129     OMNIROUTE_URL=http://127.0.0.1:20128     OMNIROUTE_SERVER_ENV=/app/omniroute-data/server.env

COPY package.json ./
COPY server.js ./

USER node
EXPOSE 20129
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3   CMD node -e "fetch('http://127.0.0.1:'+(process.env.PORT||20129)+'/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "server.js"]
