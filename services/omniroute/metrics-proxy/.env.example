# Copy to /root/services/omniroute/metrics-proxy.env on CT107 or set in Portainer.
# Never commit real token values.

PORT=20129

# From a Docker container on CT107, localhost is the container itself.
# If OmniRoute is published on the Docker host, use http://172.17.0.1:20128.
OMNIROUTE_URL=http://172.17.0.1:20128
OMNIROUTE_SERVER_ENV=/app/omniroute-data/server.env

# Shared token for dashboards/monitoring clients that call this proxy.
# Generate with: openssl rand -hex 32
OMNIROUTE_DASHBOARD_TOKEN=replace-with-random-token

OMNIROUTE_METRICS_PROXY_CACHE_SECONDS=60
OMNIROUTE_METRICS_PROXY_TIMEOUT_MS=10000
