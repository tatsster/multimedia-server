# OmniRoute environment example derived from live LXC 107.
# Copy to /root/.services/omniroute/omniroute.env or use systemd EnvironmentFile.
# Never commit the real file with secrets.

# Single-port mode: Dashboard and OpenAI-compatible API on the same port.
PORT=20128
DATA_DIR=/root/.omniroute

# Required before first run. Generate fresh values for a new homelab:
#   openssl rand -base64 48
JWT_SECRET=replace-with-generated-jwt-secret
#   openssl rand -hex 32
API_KEY_SECRET=replace-with-generated-api-key-secret
# Admin dashboard initial password. Use a strong unique value.
INITIAL_PASSWORD=replace-with-initial-admin-password

# Optional storage encryption. If enabled, back this up safely; losing it can make stored data unrecoverable.
# STORAGE_ENCRYPTION_KEY=replace-with-generated-storage-key
# STORAGE_ENCRYPTION_KEY_VERSION=v1

# Optional hardening knobs from upstream docs; uncomment after validating in your environment.
# API_HOST=0.0.0.0
# DASHBOARD_PORT=20128
# API_PORT=20129
