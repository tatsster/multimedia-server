# Beszel agent env for Proxmox host 192.168.1.101 / system `proxmox`.
# Keep secrets such as KEY/TOKEN out of this repo.

# Limit reported sensors to Intel core/package sensors.
SENSORS=coretemp*

# Use the normalized Beszel detailed stats key, not the lm-sensors display label.
# This makes Beszel all-systems dashboard populate info.dt with the package temp.
PRIMARY_SENSOR=coretemp_package_id_0
