# Cloudflare Tunnel token
# Get from Cloudflare Zero Trust -> Networks -> Tunnels -> choose tunnel -> Configure/Install connector
TUNNEL_TOKEN=<your_tunnel_token>

# Cloudflare DNS API token
# Get from Cloudflare Profile -> API Tokens -> Create custom token
# Minimum permissions commonly needed for DNS challenge/DDNS:
# - Zone:Zone:Read
# - Zone:DNS:Edit
CF_API_TOKEN=<dns_edit_token>

# Jellyfin API
# Get from Jellyfin Dashboard -> Advanced -> API Keys
JELLYFIN_URL=http://<jellyfin-ip>:8096
JELLYFIN_KEY=<jellyfin_api_key>

# Proxmox VE API token
# Get from Proxmox -> Datacenter -> Permissions -> API Tokens
# Format: <username>@pam!<tokenID>=<secret>
PROXMOXVE_URL=https://<proxmox-ip>:8006
PROXMOXVE_KEY=<username>@pam!<tokenID>=<secret>

# Proxmox Backup Server API token
# Get from PBS -> Configuration/Access Control -> API Tokens
# Format expected by widgets may differ by integration: <username>@pbs!<tokenID>:<secret>
PROXMOXBACKUP_URL=https://<pbs-ip>:8007
PROXMOXBACKUP_KEY=<username>@pbs!<tokenID>:<secret>

# qBittorrent/QBWrapper
# QB_PASSWORD is the qBittorrent WebUI password you set after first login.
# AUTH_TOKEN is generated/chosen for qbwrapper protection.
QB_PASSWORD=<qbittorrent_webui_password>
AUTH_TOKEN=<token_qbwrapper>

# Hermes -> OmniRoute
# Create OmniRoute endpoint key from OmniRoute Dashboard -> Endpoints/API Keys
OMNIROUTE_BASE_URL=http://<omniroute-lxc-ip>:20128/v1
OMNIROUTE_API_KEY=<omniroute_api_key_for_hermes>

# Hermes Proxmox tools, if used
PROXMOX_HOST=https://<proxmox-ip>:8006
PROXMOX_TOKEN_ID=<username@realm!tokenid>
PROXMOX_TOKEN_SECRET=<proxmox_token_secret>

# Discord integration, if used
# Discord Developer Portal -> Bot token, and Discord UI/developer mode for IDs.
DISCORD_BOT_TOKEN=<discord_bot_token>
DISCORD_HOME_CHANNEL=<discord_channel_id>
DISCORD_ALLOWED_USERS=<discord_user_id>

# Hermes auxiliary image generation, if enabled
# Image generation is configured separately from the chat model provider.
IMAGE_GEN_PROVIDER=<image_generation_provider>
IMAGE_GEN_MODEL=<image_generation_model>
IMAGE_GEN_API_KEY=<image_generation_api_key>
