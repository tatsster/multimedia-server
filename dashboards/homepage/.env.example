# Homepage environment variables
# Copy values into the live Homepage environment or systemd env file.
# Never commit real API tokens, passwords, or tunnel/proxy secrets.
# Homepage variable substitution requires HOMEPAGE_VAR_* names.

TZ=Asia/Ho_Chi_Minh
HOMEPAGE_ALLOWED_HOSTS=liftlab.dev,homepage.liftlab.dev,192.168.1.114:3000

# Proxmox VE widget
# Username should be token id only, for example: api-ro@pam!homepage
# Password should be the token secret only.
HOMEPAGE_VAR_PROXMOXVE_URL=https://192.168.1.101:8006
HOMEPAGE_VAR_PROXMOXVE_USERNAME=api-ro@pam!homepage
HOMEPAGE_VAR_PROXMOXVE_TOKEN=replace-with-pve-api-token-secret

# Proxmox Backup Server widget
HOMEPAGE_VAR_PROXMOXBACKUP_URL=https://192.168.1.250:8007
HOMEPAGE_VAR_PROXMOXBACKUP_USERNAME=api-ro@pam!homepage
HOMEPAGE_VAR_PROXMOXBACKUP_TOKEN=replace-with-pbs-api-token-secret

# Media widgets
HOMEPAGE_VAR_JELLYFIN_URL=https://play.liftlab.dev
HOMEPAGE_VAR_JELLYFIN_KEY=replace-with-jellyfin-api-key
HOMEPAGE_VAR_JELLYSEERR_KEY=replace-with-jellyseerr-api-key

# Beszel service link/monitoring dashboard
# Beszel remains the main monitoring/history/alerts tool for PVE metrics.
HOMEPAGE_VAR_BESZEL_URL=http://192.168.1.115:8090

# Speedtest Tracker widget
# Use the internal base URL and API token from live Speedtest Tracker.
HOMEPAGE_VAR_SPEEDTEST_URL=http://192.168.1.113
HOMEPAGE_VAR_SPEEDTEST_API_TOKEN=replace-with-speedtest-api-token

# qBittorrent widget
# Use the WebUI login. Keep qBittorrent network/interface locked to VPN only.
HOMEPAGE_VAR_QBIT_URL=http://192.168.1.103:8080
HOMEPAGE_VAR_QBIT_USERNAME=replace-with-qbittorrent-username
HOMEPAGE_VAR_QBIT_PASSWORD=replace-with-qbittorrent-password

# Arr widgets
HOMEPAGE_VAR_RADARR_API_KEY=replace-with-radarr-api-key
HOMEPAGE_VAR_SONARR_API_KEY=replace-with-sonarr-api-key
HOMEPAGE_VAR_PROWLARR_API_KEY=replace-with-prowlarr-api-key

# OmniRoute custom API widget
# Must match the token configured for the metrics proxy.
HOMEPAGE_VAR_OMNIROUTE_DASHBOARD_TOKEN=replace-with-omniroute-dashboard-token
