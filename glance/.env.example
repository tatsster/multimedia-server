# Glance dashboard environment variables
# Copy to /docker/glance/.env or pass with docker --env-file.
# Never commit the real .env file.

TZ=Asia/Ho_Chi_Minh

# Proxmox VE widget
# Create in Proxmox VE UI: Datacenter -> Permissions -> API Tokens.
# Recommended role: PVEAuditor on path / with privilege separation enabled.
PROXMOXVE_URL=192.168.1.101:8006
PROXMOXVE_KEY=api-ro@pam!glance=replace-with-pve-api-token-secret

# Proxmox Backup Server widget
# Create in PBS UI: Configuration/Access Control -> API Tokens.
# Recommended: read-only/audit token where possible.
PROXMOXBACKUP_URL=192.168.1.250:8007
PROXMOXBACKUP_KEY=api-ro@pam!glance=replace-with-pbs-api-token-secret

# Jellyfin active session widget
# Create in Jellyfin Dashboard -> API Keys.
JELLYFIN_URL=https://play.liftlab.dev
JELLYFIN_KEY=replace-with-jellyfin-api-key

# qBittorrent widget via QBWrapper/qbproxy.
# This must match AUTH_TOKEN in server-arr/.env for the qbproxy/QBWrapper service.
# Generate locally, for example: openssl rand -hex 32
QBW_URL=192.168.1.103:9911
AUTH_TOKEN=replace-with-qbwrapper-token

# Mealie daily recipe widget.
# Create in Mealie user/profile settings -> API tokens.
MEALIE_URL=https://mealie.liftlab.dev
MEALIE_API_TOKEN=replace-with-mealie-api-token

# Omniroute usage widget via token-protected metrics proxy on CT107.
# Generate the token locally, for example: openssl rand -hex 32
# The same value must be set as OMNIROUTE_DASHBOARD_TOKEN for the proxy.
OMNIROUTE_METRICS_PROXY_URL=http://192.168.1.109:20129
OMNIROUTE_DASHBOARD_TOKEN=replace-with-omniroute-dashboard-token
