# Hindsight Docker environment example
# Copy to /root/.hindsight.env on the Hindsight LXC and replace placeholders.
# Do not commit real API keys/tokens/passwords.

HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_ENABLE_API=true
HINDSIGHT_ENABLE_CP=true
HINDSIGHT_CP_DATAPLANE_API_URL=http://localhost:8888
HINDSIGHT_API_LOG_LEVEL=info

# Current homelab pattern: Hindsight calls an OpenAI-compatible OmniRoute endpoint.
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=http://192.168.1.109:20128/v1
HINDSIGHT_API_LLM_MODEL=gemini/gemini-3-flash-preview

# Secret: create/provide via OmniRoute/provider account. Keep real value only on the LXC.
HINDSIGHT_API_LLM_API_KEY=replace-with-omniroute-or-provider-api-key
