{
	# Current live setup exposes Caddy admin on all interfaces.
	# Safer default is localhost. Only use 0.0.0.0 if LAN/firewall protects it.
	# admin 0.0.0.0:2019
	admin localhost:2019

	# Optional: use Caddy as DDNS updater with Cloudflare.
	# Requires Caddy built with:
	#   github.com/mholt/caddy-dynamicdns
	#   github.com/caddy-dns/cloudflare
	dynamic_dns {
		provider cloudflare {env.CF_API_TOKEN}
		domains {
			example.com play vaultwarden flaresolverr
		}
		dynamic_domains
		versions ipv4
	}
}

*.example.com {
	# Wildcard certificate using Cloudflare DNS challenge.
	# Secret source: Cloudflare profile -> API Tokens -> custom token with Zone:DNS:Edit and Zone:Zone:Read.
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		propagation_delay 2m
		resolvers 1.1.1.1
	}

	# Media/service examples. Keep hostname spelling consistent with Cloudflare DNS/Tunnel.
	@jellyfin host play.example.com
	handle @jellyfin {
		reverse_proxy http://192.168.1.104:8096
	}

	@jellyseerr host media.example.com
	handle @jellyseerr {
		reverse_proxy http://192.168.1.105:5055
	}

	@sonarr host sonarr.example.com
	handle @sonarr {
		reverse_proxy http://192.168.1.103:8989
	}

	@radarr host radarr.example.com
	handle @radarr {
		reverse_proxy http://192.168.1.103:7878
	}

	@prowlarr host prowlarr.example.com
	handle @prowlarr {
		reverse_proxy http://192.168.1.103:9696
	}

	@bazarr host bazarr.example.com
	handle @bazarr {
		reverse_proxy http://192.168.1.103:6767
	}

	@tdarr host tdarr.example.com
	handle @tdarr {
		reverse_proxy http://192.168.1.103:8265
	}


	# Example HTTPS backend with self-signed/internal certificate.
	# Use tls_insecure_skip_verify only for trusted LAN services.
	@vaultwarden host vaultwarden.example.com
	handle @vaultwarden {
		reverse_proxy https://VAULTWARDEN_LXC_IP:8000 {
			transport http {
				tls
				tls_insecure_skip_verify
			}
		}
	}

	@flaresolverr host flaresolverr.example.com
	handle @flaresolverr {
		reverse_proxy http://192.168.1.103:8191
	}
}


# Root dashboard example. Keep the root domain outside the wildcard block.
example.com {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		propagation_delay 2m
		resolvers 1.1.1.1
	}
	reverse_proxy http://HOMEPAGE_LXC_IP:3000
}
