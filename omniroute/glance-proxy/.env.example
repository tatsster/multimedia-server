# Copy to /root/omniroute/glance-proxy.env on CT107 or set in Portainer.
# Never commit real token values.

PORT=20129
OMNIROUTE_URL=http://127.0.0.1:20128
OMNIROUTE_SERVER_ENV=/app/omniroute-data/server.env
OMNIROUTE_GLANCE_TOKEN=replace-with-random-token
OMNIROUTE_GLANCE_PROXY_CACHE_SECONDS=60
OMNIROUTE_GLANCE_PROXY_TIMEOUT_MS=10000
