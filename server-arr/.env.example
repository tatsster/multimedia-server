# Arr/media stack environment
# Copy to .env beside arr-stack.yml, then replace placeholders.

# LinuxServer.io container ownership
PUID=1000
PGID=1000
TZ=Asia/Ho_Chi_Minh

# qBittorrent WebUI
# First fresh login: read temporary password from container logs:
#   docker logs qbittorrent | grep -i password
# Then set permanent username/password in qBittorrent -> Tools -> Options -> WebUI.
# Also configure qBittorrent to bind torrent traffic only to the intended VPN
# connection/interface. Keep any VPN credentials in a local private env/config.
QB_USERNAME=replace-with-qbittorrent-webui-username
QB_PASSWORD=replace-with-qbittorrent-webui-password

# QBWrapper / qbproxy
# Choose a long random value, for example: openssl rand -hex 32
AUTH_TOKEN=replace-with-random-qbwrapper-token
